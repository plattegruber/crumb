{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/pre-commit-check.sh",
            "timeout": 120,
            "statusMessage": "Checking if this is a commit — running lint and format checks..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/lint-fix-file.sh",
            "timeout": 30,
            "statusMessage": "Auto-fixing lint and formatting..."
          }
        ]
      }
    ]
  }
}
