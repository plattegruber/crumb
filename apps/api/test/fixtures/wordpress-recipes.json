    "id": "wp-recipe-2",
    "title": "Garlic Bread",
    "description": "Simple and delicious garlic bread.",
    "ingredients": [
      { "raw_text": "1 baguette, halved lengthwise" },
      { "raw_text": "4 tablespoons butter, softened" },
      { "raw_text": "3 cloves garlic, minced" },
      { "raw_text": "2 tablespoons fresh parsley, chopped" }
    ],
    "instructions": [
      "Preheat oven to 375 degrees F.",
      "Mix butter, garlic, and parsley.",
      "Spread on baguette halves.",
      "Bake for 10-12 minutes until golden."
    ],
